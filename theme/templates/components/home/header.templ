package home

import (
	"portfolio/theme/templates/components/icons"
)

templ Header() {
	<header class="home-header" id="header">
		<div class="inner">
			<div>
				<p class="hello">Welcome, I am</p>
				<h1 class="name">Péter<br/>Szarvas</h1>
				<p class="subtitle">full-stack developer</p>
			</div>
			@SectionLink("about") {
				<div>
					[&nbsp;<span>about</span>&nbsp;]
				</div>
				@icons.Chevron("bounce-icon")
			}
		</div>
	</header>
}
