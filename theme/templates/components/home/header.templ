package home

templ Header() {
	<header class="home-header" id="header">
		<div class="inner">
			<div>
				<p class="hello">Welcome, I am</p>
				<h1 class="name">Péter<br/>Szarvas</h1>
				<p class="subtitle">full-stack developer</p>
			</div>
			@SectionLink("about") {
				<div>
					<span class="art">↓</span>&nbsp;<span>about</span>&nbsp;<span class="art">↓</span>
				</div>
			}
		</div>
	</header>
}
