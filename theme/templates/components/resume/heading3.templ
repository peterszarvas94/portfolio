package resume

templ Heading3(text, desc string) {
	<h3 class="flex gap-2 items-center">
		<p class="text-lg text-base-content font-bold ">{ text }</p>
		<p>{ desc }</p>
	</h3>
}

templ Heading3Link(text, link, desc string) {
	<h3 class="flex gap-2 items-center">
		<a href={ link } target="_blank" rel="noopener noreferrer">
			<p class="text-lg text-base-content font-bold ">{ text }</p>
		</a>
		<p>{ desc }</p>
	</h3>
}
